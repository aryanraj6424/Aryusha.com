# ─── Backend .env ──────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"aryusha-6596a",...}
# Paste the full Firebase service-account JSON as a single-line string above.
# Generate it in: Firebase Console → Project Settings → Service Accounts → Generate new private key

# ─── Frontend .env ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
